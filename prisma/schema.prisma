// ============================================================
// Sistem Informasi Manajemen BMN Terpadu — BPS Kota Palu
// Prisma Schema — sumber tunggal struktur database (ERD -> kode)
// Jalankan migrasi otomatis dengan: npx prisma migrate dev --name init
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ------------------------------------------------------------
// ENUM
// ------------------------------------------------------------

enum Role {
  super_admin
  admin
  kasubag
}

enum KondisiAset {
  baik
  rusak_ringan
  rusak_berat
}

enum StatusAset {
  aktif
  non_aktif
}

enum JenisJabatan {
  kepala_bps
  kasubag
}

// ------------------------------------------------------------
// 1. AKSES & MASTER DATA UMUM
// ------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  nama      String
  email     String   @unique
  role      Role
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  batchSuratBelanja  BatchSuratBelanja[]
  batchPembelianAset BatchPembelianAset[]
  mutasiAset         MutasiAset[]
  riwayatKondisiAset RiwayatKondisiAset[]

  @@map("users")
}

model Ruangan {
  id            String   @id @default(uuid())
  kodeRuangan   String   @unique @map("kode_ruangan")
  namaRuangan   String   @map("nama_ruangan")
  lantaiLokasi  String?  @map("lantai_lokasi")
  keterangan    String?
  createdAt     DateTime @default(now()) @map("created_at")

  // Lokasi terkini aset (1 ruangan -> banyak aset)
  masterAset MasterAset[] @relation("RuanganSaatIni")

  // Dua relasi berbeda ke mutasi_aset: sebagai ruangan asal & ruangan tujuan
  mutasiAsalDari    MutasiAset[] @relation("RuanganAsal")
  mutasiTujuanKe    MutasiAset[] @relation("RuanganTujuan")

  @@map("ruangan")
}

model PengaturanTtd {
  id            String       @id @default(uuid())
  jenisJabatan  JenisJabatan @map("jenis_jabatan")
  namaPejabat   String       @map("nama_pejabat")
  nip           String
  jabatan       String
  isActive      Boolean      @default(true) @map("is_active")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("pengaturan_ttd")
}

// ------------------------------------------------------------
// 2. MODUL PERSEDIAAN (ATK) — FIFO
// ------------------------------------------------------------

model KategoriBarang {
  id           String @id @default(uuid())
  namaKategori String @map("nama_kategori")

  masterBarang MasterBarang[]

  @@map("kategori_barang")
}

model MasterBarang {
  id               String   @id @default(uuid())
  kategoriBarangId String   @map("kategori_barang_id")
  namaBarang       String   @map("nama_barang")
  satuan           String
  stokMinimum      Int      @map("stok_minimum")
  stokAktual       Int      @default(0) @map("stok_aktual")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  kategori          KategoriBarang      @relation(fields: [kategoriBarangId], references: [id])
  batchSuratBelanja BatchSuratBelanja[]
  transaksiAtk      TransaksiAtk[]

  @@map("master_barang")
}

model BatchSuratBelanja {
  id              String   @id @default(uuid())
  masterBarangId  String   @map("master_barang_id")
  noSuratBelanja  String   @map("no_surat_belanja")
  tanggalBelanja  DateTime @map("tanggal_belanja") @db.Date
  hargaSatuan     Decimal  @map("harga_satuan") @db.Decimal(14, 2)
  qtyMasuk        Int      @map("qty_masuk")
  sisaQty         Int      @map("sisa_qty")
  dicatatOleh     String   @map("dicatat_oleh")
  createdAt       DateTime @default(now()) @map("created_at")

  masterBarang       MasterBarang         @relation(fields: [masterBarangId], references: [id])
  pencatat           User                 @relation(fields: [dicatatOleh], references: [id])
  transaksiAtkDetail TransaksiAtkDetail[]

  @@map("batch_surat_belanja")
}

model TransaksiAtk {
  id                 String   @id @default(uuid())
  masterBarangId     String   @map("master_barang_id")
  namaPegawai        String   @map("nama_pegawai")
  unitKerja          String   @map("unit_kerja")
  qtyDiambil         Int      @map("qty_diambil")
  tanggalPengambilan DateTime @default(now()) @map("tanggal_pengambilan")

  masterBarang MasterBarang         @relation(fields: [masterBarangId], references: [id])
  detail       TransaksiAtkDetail[]

  @@map("transaksi_atk")
}

// Rincian FIFO: 1 transaksi bisa dipenuhi dari lebih dari 1 batch surat belanja
model TransaksiAtkDetail {
  id                  String  @id @default(uuid())
  transaksiAtkId      String  @map("transaksi_atk_id")
  batchSuratBelanjaId String  @map("batch_surat_belanja_id")
  qtyDipakai          Int     @map("qty_dipakai")
  hargaSaatPakai      Decimal @map("harga_saat_pakai") @db.Decimal(14, 2)

  transaksiAtk      TransaksiAtk      @relation(fields: [transaksiAtkId], references: [id])
  batchSuratBelanja BatchSuratBelanja @relation(fields: [batchSuratBelanjaId], references: [id])

  @@map("transaksi_atk_detail")
}

// ------------------------------------------------------------
// 3. MODUL ASET TETAP (NUP)
// ------------------------------------------------------------

model KategoriAset {
  id           String @id @default(uuid())
  namaKategori String @map("nama_kategori")

  batchPembelianAset BatchPembelianAset[]

  @@map("kategori_aset")
}

model BatchPembelianAset {
  id             String   @id @default(uuid())
  kategoriAsetId String   @map("kategori_aset_id")
  noSuratBelanja String   @map("no_surat_belanja")
  tanggalBeli    DateTime @map("tanggal_beli") @db.Date
  namaAset       String   @map("nama_aset")
  merekTipe      String?  @map("merek_tipe")
  hargaSatuan    Decimal  @map("harga_satuan") @db.Decimal(14, 2)
  jumlahUnit     Int      @map("jumlah_unit")
  dicatatOleh    String   @map("dicatat_oleh")
  createdAt      DateTime @default(now()) @map("created_at")

  kategori   KategoriAset @relation(fields: [kategoriAsetId], references: [id])
  pencatat   User         @relation(fields: [dicatatOleh], references: [id])
  masterAset MasterAset[]

  @@map("batch_pembelian_aset")
}

model MasterAset {
  id                String      @id @default(uuid())
  batchPembelianId  String      @map("batch_pembelian_id")
  nup               String      @unique
  ruanganId         String      @map("ruangan_id")
  kondisi           KondisiAset @default(baik)
  statusAset        StatusAset  @default(aktif) @map("status_aset")
  createdAt         DateTime    @default(now()) @map("created_at")

  batchPembelian     BatchPembelianAset  @relation(fields: [batchPembelianId], references: [id])
  ruangan            Ruangan             @relation("RuanganSaatIni", fields: [ruanganId], references: [id])
  mutasiAset         MutasiAset[]
  riwayatKondisiAset RiwayatKondisiAset[]

  @@map("master_aset")
}

// Riwayat mutasi ruangan — append-only, jangan pernah di-update/delete
model MutasiAset {
  id               String   @id @default(uuid())
  asetId           String   @map("aset_id")
  ruanganAsalId    String   @map("ruangan_asal_id")
  ruanganTujuanId  String   @map("ruangan_tujuan_id")
  tanggalMutasi    DateTime @map("tanggal_mutasi") @db.Date
  keterangan       String?
  dicatatOleh      String   @map("dicatat_oleh")
  createdAt        DateTime @default(now()) @map("created_at")

  aset          MasterAset @relation(fields: [asetId], references: [id])
  ruanganAsal   Ruangan    @relation("RuanganAsal", fields: [ruanganAsalId], references: [id])
  ruanganTujuan Ruangan    @relation("RuanganTujuan", fields: [ruanganTujuanId], references: [id])
  pencatat      User       @relation(fields: [dicatatOleh], references: [id])

  @@map("mutasi_aset")
}

// Riwayat perubahan kondisi fisik — append-only, jangan pernah di-update/delete
model RiwayatKondisiAset {
  id                String      @id @default(uuid())
  asetId            String      @map("aset_id")
  kondisiLama       KondisiAset @map("kondisi_lama")
  kondisiBaru       KondisiAset @map("kondisi_baru")
  tanggalPerubahan  DateTime    @map("tanggal_perubahan") @db.Date
  keterangan        String?
  dicatatOleh       String      @map("dicatat_oleh")
  createdAt         DateTime    @default(now()) @map("created_at")

  aset     MasterAset @relation(fields: [asetId], references: [id])
  pencatat User       @relation(fields: [dicatatOleh], references: [id])

  @@map("riwayat_kondisi_aset")
}
